# Root Env example (usually applied to Backend, but kept here for reference)
DATABASE_URL="postgresql://callmind:callmindpassword@localhost:5432/callmind_db?schema=public"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="callmindredispassword"

# JWT Config
JWT_SECRET="super-secret-jwt-key-replace-in-production"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="super-secret-refresh-key-replace-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend Env example
NEXT_PUBLIC_API_URL="http://localhost:3000"
